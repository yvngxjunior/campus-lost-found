# ──────────────────────────────────────────────────────────────────────────────
# Campus Lost & Found — Variables d'environnement
# Copier ce fichier en .env et remplir toutes les valeurs avant de démarrer
# ──────────────────────────────────────────────────────────────────────────────

# ── Base de données ───────────────────────────────────────────────────────────
# Dev local  : postgresql://user:password@localhost:5432/campus_lost_found
# Prod       : utiliser une URL avec SSL et un utilisateur dédié (pas postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/campus_lost_found"

# Base séparée pour les tests automatisés (Jest)
TEST_DATABASE_URL="postgresql://user:password@localhost:5432/campus_lost_found_test"

# ── JWT ───────────────────────────────────────────────────────────────────────
# En prod : générer avec `openssl rand -base64 64`
JWT_SECRET="change_me_to_a_long_random_string_min_32_chars"
JWT_EXPIRES_IN="7d"

# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=3000
# Valeurs : development | production | test
NODE_ENV=development

# Origine autorisée pour CORS (frontend URL)
# Dev   : http://localhost:5173
# Prod  : https://campus-lost-found.isep.fr
CLIENT_ORIGIN="http://localhost:5173"

# ── Uploads de fichiers ───────────────────────────────────────────────────────
# Stockage local (dev uniquement)
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=5

# Stockage S3 / compatible S3 (prod recommandé)
# Décommenter et remplir pour activer le stockage cloud
# STORAGE_DRIVER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-3
# AWS_S3_BUCKET=campus-lost-found-uploads
# AWS_S3_BASE_URL=https://campus-lost-found-uploads.s3.eu-west-3.amazonaws.com

# ── Email (notifications) ─────────────────────────────────────────────────────
# Désactivé par défaut — décommenter pour activer les notifications email
# SMTP_HOST=smtp.isep.fr
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@isep.fr
# SMTP_PASS=
# MAIL_FROM="Campus Lost & Found <noreply@isep.fr>"

# ── Whitelist emails campus ───────────────────────────────────────────────────
ALLOWED_EMAIL_DOMAINS="eleve.isep.fr,isep.fr"

# ── Sécurité (prod) ───────────────────────────────────────────────────────────
# Rate limiting (requêtes max par fenêtre de 15 min par IP)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Cookie sécurisé — mettre à true en HTTPS (prod)
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=strict

# ── Redis (optionnel — cache & sessions) ──────────────────────────────────────
# Décommenter pour activer le cache des résultats de recherche
# REDIS_URL=redis://localhost:6379

# ── Logging ───────────────────────────────────────────────────────────────────
# Niveau de log : error | warn | info | debug
LOG_LEVEL=info
# En prod : logs au format JSON pour ingestion (Datadog, Loki, etc.)
# LOG_FORMAT=json
