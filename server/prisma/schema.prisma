// Prisma schema — Campus Lost & Found
// 7 entities matching the ER model from the cahier des charges

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  STAFF
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ReportType {
  LOST
  FOUND
}

enum ItemStatus {
  PENDING     // awaiting admin moderation
  VERIFIED    // published & visible
  CLAIMED     // returned to owner
  REJECTED    // rejected by admin
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  ITEM_VERIFIED
  ITEM_REJECTED
  NEW_MESSAGE
  CLAIM_APPROVED
  CLAIM_REJECTED
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id            String      @id @default(uuid())
  username      String      @unique
  email         String      @unique
  passwordHash  String
  role          Role        @default(STUDENT)
  status        UserStatus  @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  items             Item[]          @relation("reporter")
  moderatedItems    Item[]          @relation("moderator")
  claimedItems      Item[]          @relation("claimedBy")
  sentMessages      Message[]       @relation("sender")
  receivedMessages  Message[]       @relation("recipient")
  claimRequests     ClaimRequest[]
  notifications     Notification[]

  @@map("users")
}

// ─── Location ─────────────────────────────────────────────────────────────────

model Location {
  id          String   @id @default(uuid())
  name        String   @unique // e.g. "Bibliothèque", "Cafétéria"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items Item[]

  @@map("locations")
}

// ─── Category ─────────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(uuid())
  name        String   @unique // e.g. "Électronique", "Livres", "Vêtements"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items Item[]

  @@map("categories")
}

// ─── Item ─────────────────────────────────────────────────────────────────────

model Item {
  id               String     @id @default(uuid())
  reportType       ReportType
  status           ItemStatus @default(PENDING)
  name             String
  description      String
  dateSignaled     DateTime   @default(now())
  dateLostFound    DateTime?
  moderationNote   String?
  claimedAt        DateTime?

  // Foreign keys
  reporterId       String
  locationId       String
  categoryId       String
  moderatorId      String?
  claimedById      String?

  // Relations
  reporter         User           @relation("reporter",  fields: [reporterId],   references: [id])
  location         Location       @relation(fields: [locationId],  references: [id])
  category         Category       @relation(fields: [categoryId],  references: [id])
  moderator        User?          @relation("moderator",  fields: [moderatorId],  references: [id])
  claimedBy        User?          @relation("claimedBy", fields: [claimedById],  references: [id])
  photos           Photo[]
  messages         Message[]
  claimRequests    ClaimRequest[]
  notifications    Notification[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([name])
  @@index([description])

  @@map("items")
}

// ─── Photo ────────────────────────────────────────────────────────────────────

model Photo {
  id        String   @id @default(uuid())
  itemId    String
  url       String
  caption   String?
  createdAt DateTime @default(now())

  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("photos")
}

// ─── Message ──────────────────────────────────────────────────────────────────

model Message {
  id          String   @id @default(uuid())
  senderId    String
  recipientId String
  itemId      String
  content     String
  sentAt      DateTime @default(now())
  readAt      DateTime?

  sender      User     @relation("sender",    fields: [senderId],    references: [id])
  recipient   User     @relation("recipient", fields: [recipientId], references: [id])
  item        Item     @relation(fields: [itemId],      references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─── ClaimRequest ─────────────────────────────────────────────────────────────

model ClaimRequest {
  id             String      @id @default(uuid())
  itemId         String
  requesterId    String
  requestMessage String
  status         ClaimStatus @default(PENDING)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  item           Item        @relation(fields: [itemId],      references: [id], onDelete: Cascade)
  requester      User        @relation(fields: [requesterId], references: [id])

  @@map("claim_requests")
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  message   String
  itemId    String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      Item?            @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@map("notifications")
}
